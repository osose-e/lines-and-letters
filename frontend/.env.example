# API URL for the Flask backend (Cloud Run). Used at build time.
# Copy to .env and set to your deployed Cloud Run URL, e.g.:
# REACT_APP_API_URL=https://flask-fire-xxxxx-uc.a.run.app
REACT_APP_API_URL=

# Realtime Database URL – must match the backend's database (same Firebase project).
# Get it from Firebase Console → Realtime Database. Only set if different from default.
# REACT_APP_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.comhttps://lines-and-letters--lines-and-letters-game.us-central1.hosted.app
